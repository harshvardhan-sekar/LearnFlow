# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: use the asyncpg scheme directly.
# Railway: auto-provisioned as postgresql:// — start.sh rewrites it automatically.
DATABASE_URL=postgresql+asyncpg://srl_user:password@localhost:5432/srl_tool

# ── LLM ───────────────────────────────────────────────────────────────────────
# OpenRouter (uses OpenAI SDK format with a different base_url)
OPENROUTER_API_KEY=sk-or-v1-...

# ── Search ────────────────────────────────────────────────────────────────────
SERPER_API_KEY=...

# ── Firebase (backend — service account for token verification) ───────────────
FIREBASE_PROJECT_ID=your-project-id
# Local dev: path to the JSON file
FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json
# Railway / CI: paste the full service-account JSON as a single-line string instead
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ── Firebase (frontend — client config as JSON string) ────────────────────────
VITE_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}

# ── API URL (frontend → backend) ──────────────────────────────────────────────
# Local dev:
VITE_API_URL=http://localhost:8000
# Railway: set to the Railway backend service public URL
# VITE_API_URL=https://backend-xxx.up.railway.app

# ── CORS (backend — optional) ─────────────────────────────────────────────────
# Comma-separated extra allowed origins beyond localhost and *.up.railway.app.
# Only needed when using a custom domain for the frontend.
# ALLOWED_ORIGINS=https://learnflow.yourdomain.com
